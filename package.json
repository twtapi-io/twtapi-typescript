{
  "name": "twtapi",
  "version": "0.1.0",
  "description": "Official TypeScript / Node.js client for the twtapi.io HTTP API.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["twitter", "x", "twtapi", "api", "sdk", "client"],
  "author": "twtapi.io",
  "license": "MIT",
  "homepage": "https://twtapi.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/twtapi-io/twtapi-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/twtapi-io/twtapi-typescript/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "msw": "^2.7.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
